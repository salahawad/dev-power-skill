# Developer Efficiency Report — Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Git Host (GitLab or GitHub) ---
GIT_HOST_URL=https://gitlab.example.com/group-name   # or https://github.com/org-name
GITLAB_TOKEN=glpat-xxxxxxxxxxxx                       # GitLab PAT (if using GitLab)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx                       # GitHub PAT (if using GitHub)

# --- Jira ---
JIRA_URL=https://company.atlassian.net
JIRA_PROJECT=DEV
JIRA_EMAIL=user@company.com
JIRA_TOKEN=ATATT3xFfGF0xxxx

# --- Report Options ---
REPORT_PERIOD_DAYS=90
